# -------- Core Runtime --------
NODE_ENV=development

# -------- Nginx --------
NGINX_HTTP_PORT=8080
NGINX_MINIO_CONSOLE_PORT=9001

# -------- Next.js --------
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# -------- Directus --------
DIRECTUS_PORT=8055
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=ChangeMe_123456
DIRECTUS_KEY=replace-with-random-key
DIRECTUS_SECRET=replace-with-random-secret

# -------- Postgres --------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hctxf
POSTGRES_USER=hctxf_user
POSTGRES_PASSWORD=ChangeMe_DB_123456

# -------- MinIO --------
# If 9000 is occupied locally, change MINIO_API_PORT and keep Nginx proxy stable.
MINIO_API_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=hctxf-assets
MINIO_REGION=us-east-1

# -------- Redis --------
REDIS_PORT=6379

# -------- Migration --------
MIGRATION_REPORT_DIR=./reports/migration
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=replace-with-directus-static-token
